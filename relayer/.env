#与 GameConfig.BROKERCHAIN_RPC相同
RPC_URL=http://192.168.1.13:36944

GATEWAY_MODE=true
GATEWAY_BASE_URL=https://dash.broker-chain.com:443

#部署的GAME_FACTORY合约地址
GAME_FACTORY_ADDRESS=0xd24F6d9A685EccF270241f40804a6Ebf5A1E2f54

# 用于发送 submitRandomWord 交易的账户私钥（0x 开头）
RELAYER_PRIVATE_KEY=0x3307b1ceae02f7cd13cca042532796858c8bd2df1f4fa4844e6b969d5ef4fdcd

# 用于生成 ECVRF 证明的私钥（0x 开头）。可与 RELAYER_PRIVATE_KEY 相同，但建议分离保管。
VRF_SECRET_KEY=0xa188e46f82d21b2adbe7dadbb66dcea07c74fb56f2e5954e8c31505bfd72df83

# 已部署的 ECVRFRelay 合约地址
ECVRF_RELAY_ADDRESS=0x023B27D2edA8F0B2CDb1C9d5e8172f75fCc7b81F

# 可选：只处理某个房间（不填则监听全网所有房间的 ECVRFRandomRequested）
ONLY_ROOM_ADDRESS=

# 可选：轮询区块间隔（毫秒），WebSocket 不可用时用
POLL_INTERVAL_MS=2000

START_BACKTRACK_BLOCKS=200
